# Server configuration
PORT=3001

# Network settings (TESTNET or PUBLIC)
NETWORK=TESTNET

# Soroban contract settings
CONTRACT_ID=your_deployed_contract_id_here

# Admin wallet secret key (KEEP THIS SECURE!)
ADMIN_SECRET_KEY=your_admin_secret_key_here

# Fee address (optional, defaults to admin address)
FEE_ADDRESS=fee_recipient_public_key_here

# CORS settings
CORS_ORIGIN=http://localhost:3000